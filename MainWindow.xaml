<Window x:Class="SonoPilotModbus.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SonoPilot Modbus RTU" Height="600" Width="480"
        Background="#1E1E2E" Foreground="#CDD6F4"
        FontFamily="Segoe UI" FontSize="13">
    <Window.Resources>
        <SolidColorBrush x:Key="CatSurface0" Color="#313244"/>
        <SolidColorBrush x:Key="CatSurface1" Color="#45475A"/>
        <SolidColorBrush x:Key="CatText" Color="#CDD6F4"/>
        <SolidColorBrush x:Key="CatSubtext0" Color="#A6ADC8"/>
        <SolidColorBrush x:Key="CatGreen" Color="#A6E3A1"/>
        <SolidColorBrush x:Key="CatRed" Color="#F38BA8"/>
        <SolidColorBrush x:Key="CatBlue" Color="#89B4FA"/>
        <SolidColorBrush x:Key="CatYellow" Color="#F9E2AF"/>
        <SolidColorBrush x:Key="CatMauve" Color="#CBA6F7"/>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource CatSurface0}"/>
            <Setter Property="Foreground" Value="{StaticResource CatText}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CatSurface1}"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="3"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Connection -->
        <Border Grid.Row="0" Background="{StaticResource CatSurface0}" CornerRadius="8" Padding="10" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="Connection" FontWeight="Bold" Foreground="{StaticResource CatMauve}" Margin="0,0,0,6"/>
                <WrapPanel>
                    <ComboBox x:Name="CmbPort" Width="100" Height="28"/>
                    <TextBlock Text=" ID:" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtSlaveId" Width="35" Height="28" Text="1"
                             Background="{StaticResource CatSurface0}" Foreground="{StaticResource CatText}"/>
                    <Button x:Name="BtnConnect" Content="Connect" Click="BtnConnect_Click"/>
                    <Button Content="⟳" Click="BtnRefresh_Click" Width="32"/>
                </WrapPanel>
                <TextBlock x:Name="TxtStatus" Text="Disconnected" Foreground="{StaticResource CatRed}" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Monitor -->
        <Border Grid.Row="1" Background="{StaticResource CatSurface0}" CornerRadius="8" Padding="10" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="Monitor" FontWeight="Bold" Foreground="{StaticResource CatGreen}" Margin="0,0,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="TxtState" Text="State: —"/>
                        <TextBlock x:Name="TxtTrack" Text="Track: —"/>
                        <TextBlock x:Name="TxtVolume" Text="Volume: —"/>
                        <TextBlock x:Name="TxtRepeat" Text="Repeat: —"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock x:Name="TxtUptime" Text="Uptime: —"/>
                        <TextBlock x:Name="TxtTemp" Text="Temp: —"/>
                        <TextBlock x:Name="TxtSD" Text="SD: —"/>
                        <TextBlock x:Name="TxtFormat" Text="Format: —"/>
                    </StackPanel>
                </Grid>
                <TextBlock x:Name="TxtTrackName" Text="♪ —" FontSize="14" Foreground="{StaticResource CatYellow}" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <!-- Control -->
        <Border Grid.Row="2" Background="{StaticResource CatSurface0}" CornerRadius="8" Padding="10" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="Control" FontWeight="Bold" Foreground="{StaticResource CatBlue}" Margin="0,0,0,6"/>
                <WrapPanel>
                    <Button Content="▶ Play" Click="BtnPlay_Click"/>
                    <Button Content="⏹ Stop" Click="BtnStop_Click"/>
                    <Button Content="⏭ Next" Click="BtnNext_Click"/>
                    <Button Content="⏮ Prev" Click="BtnPrev_Click"/>
                    <Button Content="⏸ Pause" Click="BtnPause_Click"/>
                </WrapPanel>
                <WrapPanel Margin="0,6,0,0">
                    <TextBlock Text="Vol:" VerticalAlignment="Center"/>
                    <Slider x:Name="SliderVol" Width="180" Minimum="0" Maximum="100" Value="80"
                            ValueChanged="SliderVol_Changed" IsSnapToTickEnabled="True" TickFrequency="1"/>
                    <TextBlock x:Name="TxtVol" Text="80%" Width="40" VerticalAlignment="Center"/>
                </WrapPanel>
                <WrapPanel Margin="0,6,0,0">
                    <TextBlock Text="Repeat:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox x:Name="CmbRepeat" Width="90" Height="26" SelectedIndex="0" SelectionChanged="CmbRepeat_Changed">
                        <ComboBoxItem Content="All"/>
                        <ComboBoxItem Content="One"/>
                        <ComboBoxItem Content="Off"/>
                        <ComboBoxItem Content="Single"/>
                        <ComboBoxItem Content="Random"/>
                    </ComboBox>
                    <Button x:Name="BtnMono" Content="Mono: Off" Click="BtnMono_Click"/>
                    <Button x:Name="BtnAutoplay" Content="Auto: On" Click="BtnAutoplay_Click"/>
                    <TextBlock Text=" Goto#" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtGoto" Width="35" Height="26" Text="0"
                             Background="{StaticResource CatSurface0}" Foreground="{StaticResource CatText}"/>
                    <Button Content="Go" Click="BtnGoto_Click"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Raw Register -->
        <Border Grid.Row="3" Background="{StaticResource CatSurface0}" CornerRadius="8" Padding="10" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="Raw Register" FontWeight="Bold" Foreground="{StaticResource CatSubtext0}" Margin="0,0,0,6"/>
                <WrapPanel>
                    <TextBlock Text="0x" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtRegAddr" Width="45" Height="26" Text="0000"
                             Background="{StaticResource CatSurface0}" Foreground="{StaticResource CatText}"/>
                    <TextBlock Text=" n:" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtRegCount" Width="30" Height="26" Text="1"
                             Background="{StaticResource CatSurface0}" Foreground="{StaticResource CatText}"/>
                    <Button Content="Read" Click="BtnRegRead_Click"/>
                    <TextBlock Text=" =0x" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtRegVal" Width="50" Height="26" Text="0000"
                             Background="{StaticResource CatSurface0}" Foreground="{StaticResource CatText}"/>
                    <Button Content="Write" Click="BtnRegWrite_Click"/>
                </WrapPanel>
                <TextBlock x:Name="TxtRegResult" Text="" Foreground="{StaticResource CatSubtext0}" Margin="0,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Log -->
        <Border Grid.Row="4" Background="{StaticResource CatSurface0}" CornerRadius="8" Padding="10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Log" FontWeight="Bold" Foreground="{StaticResource CatSubtext0}" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtLog" IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                         Background="#181825" Foreground="{StaticResource CatSubtext0}" FontFamily="Cascadia Mono,Consolas"
                         FontSize="11" TextWrapping="Wrap" BorderThickness="0"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
